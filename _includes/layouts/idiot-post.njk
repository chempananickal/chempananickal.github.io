---
layout: layouts/idiot-base.njk
heroTitle: James' Silly Website
heroSuffix: Blog
---
<article class="content-box idiot-article">
  <p class="idiot-kicker">Posted {{ page.date | postDate }}</p>
  <h2 class="idiot-post-title">{{ title }}</h2>
  {% if description %}
    <p class="idiot-lede">{{ description }}</p>
  {% endif %}
  <div class="idiot-prose">
    {{ content | safe }}
  </div>
</article>